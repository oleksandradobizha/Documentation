# Server
PORT=8080

# GitHub - repo where testcases.json lives (this repo)
GITHUB_TOKEN=ghp_replace_me_with_fine_grained_PAT
GITHUB_OWNER=oleksandradobizha
GITHUB_REPO=Documentation
GITHUB_BRANCH=main
DATA_PATH=data/testcases.json
DOCS_PATH=data/documentation.json
JIRA_PATH=data/jiratickets.json

# Shared secret required for write endpoints (any long random string)
API_KEY=change-me-to-a-long-random-string

# CORS - where the frontend is served from
ALLOWED_ORIGIN=https://oleksandradobizha.github.io

# ---------------------------------------------------------------------------
# AI Agent - generates draft test cases from a JIRA ticket
# NEVER commit this file. Keep secrets only in your local .env.
# ---------------------------------------------------------------------------

# Google Gemini API key (free tier) - https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional - override the default model
GEMINI_MODEL=gemini-2.5-flash

# Optional - override the system prompt (persona + skills + rules) sent to Gemini.
# By default backend/src/prompts/testcase.md is used. Set either of these to
# override without editing code:
#   GEMINI_SYSTEM_PROMPT        - full prompt inline (takes precedence).
#   GEMINI_SYSTEM_PROMPT_PATH   - path to an alternate .md / .txt file
#                                  (absolute, or relative to the backend cwd).
GEMINI_SYSTEM_PROMPT=
GEMINI_SYSTEM_PROMPT_PATH=

# JIRA Cloud - Basic auth with email + API token
# Create a token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# ---------------------------------------------------------------------------
# Automation "Run" button - URL that opens for each test case.
# Supports the {id} placeholder, replaced with the test case id (e.g. TC-0001).
# Example:
#   https://github.com/your-org/your-automation-repo/actions?query=TC-0001
# Leave blank to hide the button entirely.
# ---------------------------------------------------------------------------
AUTOMATION_ACTIONS_URL=
